{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "API Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"exasense\"}[5m])) by (method)",
          "legendFormat": "{{ method }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Response Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"exasense\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"exasense\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"exasense\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"exasense\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"exasense\"}[5m]))",
          "legendFormat": "5xx rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    },
    {
      "title": "Simulation Pipeline",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "title": "Celery Queue Length",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "celery_queue_length{namespace=\"exasense\"}",
          "legendFormat": "{{ queue }}"
        }
      ]
    },
    {
      "title": "Task Processing Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(celery_task_runtime_seconds_bucket{namespace=\"exasense\"}[5m])) by (le, name))",
          "legendFormat": "{{ name }} p95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Active Workers",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "count(up{job=~\".*celery.*\", namespace=\"exasense\"} == 1)",
          "legendFormat": "Workers"
        }
      ]
    },
    {
      "title": "GPU Monitoring",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "title": "GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{ gpu }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100, "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 70 },
          { "color": "red", "value": 90 }
        ]}}
      }
    },
    {
      "title": "GPU Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED / 1024",
          "legendFormat": "Used (GiB)"
        },
        {
          "expr": "DCGM_FI_DEV_FB_TOTAL / 1024",
          "legendFormat": "Total (GiB)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decgbytes" }
      }
    },
    {
      "title": "GPU Temperature",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "GPU {{ gpu }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "celsius", "thresholds": { "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 75 },
          { "color": "red", "value": 85 }
        ]}}
      }
    },
    {
      "title": "Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "title": "Pod Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "kube_pod_status_phase{namespace=\"exasense\"}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "PVC Usage",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "kubelet_volume_stats_used_bytes{namespace=\"exasense\"} / kubelet_volume_stats_capacity_bytes{namespace=\"exasense\"}",
          "legendFormat": "{{ persistentvolumeclaim }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1 }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["exasense"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Tokyo",
  "title": "ExaSense Overview",
  "uid": "exasense-overview"
}
